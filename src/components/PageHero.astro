---
interface Props {
  eyebrow: string;
  heading: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { eyebrow, heading, ctaLabel, ctaHref } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero-inner">
    <!-- Left: text -->
    <div class="page-hero-content">
      <p class="page-hero-eyebrow">
        <span class="eyebrow-arrow">→</span> {eyebrow}
      </p>
      <h1 class="heading-1 page-hero-heading">{heading}</h1>
      {ctaLabel && ctaHref && (
        <a href={ctaHref} class="btn btn-primary page-hero-cta">
          {ctaLabel}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      )}
    </div>

    <!-- Right: image + geometric pattern -->
    <div class="page-hero-image-wrap">
      <div class="page-hero-pattern"></div>
      <img
        src="/images/About-Us-1.webp"
        alt="EB-1A Green Card Coach"
        class="page-hero-image"
        width="520"
        height="420"
      />
    </div>
  </div>
</section>

<style>
  .page-hero {
    background-color: var(--color-navy);
    overflow: hidden;
  }

  .page-hero-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: flex-end;
    min-height: 320px;
  }

  /* ── Left ──────────────────────────────────── */
  .page-hero-content {
    padding-block: 60px 50px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .page-hero-eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: rgba(255,255,255,0.75);
    letter-spacing: var(--ls-wide);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .eyebrow-arrow {
    color: var(--color-primary);
    font-size: 16px;
  }

  .page-hero-heading {
    color: var(--color-white);
    font-size: clamp(32px, 4vw, 52px);
    line-height: 1.15;
  }

  .page-hero-cta {
    align-self: flex-start;
    margin-top: var(--sp-2);
  }

  /* ── Right: image + diamond lattice pattern ── */
  .page-hero-image-wrap {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 100%;
  }

  .page-hero-pattern {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 28px,
        rgba(255,255,255,0.07) 28px,
        rgba(255,255,255,0.07) 29px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 28px,
        rgba(255,255,255,0.07) 28px,
        rgba(255,255,255,0.07) 29px
      );
    pointer-events: none;
  }

  .page-hero-image {
    position: relative;
    z-index: 1;
    height: 320px;
    width: auto;
    object-fit: contain;
    object-position: bottom;
    display: block;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 768px) {
    .page-hero-inner {
      grid-template-columns: 1fr;
    }

    .page-hero-image-wrap {
      display: none;
    }

    .page-hero-content {
      padding-block: 48px 40px;
    }
  }
</style>
