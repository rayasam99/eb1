---
const quickLinks = [
  { label: 'Home',           href: '/' },
  { label: 'Who We Are',     href: '/who-are-we' },
  { label: 'What is EB-1A?', href: '/what-is-eb-1a' },
  { label: 'Contact Us',     href: '/contact-us' },
  { label: 'Blog',           href: '/blog' },
];
---

<footer class="site-footer">

  <!-- Main Footer Body -->
  <div class="footer-body">
    <div class="container footer-grid">

      <!-- Column 1 — Tagline -->
      <div class="footer-col footer-col--tagline">
        <p class="footer-tagline heading-2 text-light">
          Let's Talking Together Connecting Peoples
        </p>
      </div>

      <!-- Column 2 — Logo + Contact -->
      <div class="footer-col footer-col--contact">
        <a href="/" class="footer-logo" aria-label="EB-1A Green Card Coach">
          <img
            src="/images/EB-1A-Logo-For-Web-White.png"
            alt="EB-1A Green Card Coach"
            width="160"
            height="54"
            class="footer-logo-img"
          />
        </a>
        <p class="footer-brand-name">EB-1A Green Card Coach</p>

        <ul class="footer-contact-list">
          <li class="footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+13054899346">(305) 489-9346</a>
          </li>
          <li class="footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:contact@eb1agreencardcoach.com">contact@eb1agreencardcoach.com</a>
          </li>
          <li class="footer-contact-item footer-contact-item--address">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <address>1580 Sawgrass Corporate Pkwy,<br />Suite 130 Sunrise, FL 33323</address>
          </li>
        </ul>

        <!-- Social Icons -->
        <div class="footer-social">
          <a href="#" class="footer-social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" class="footer-social-link" aria-label="Twitter" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          </a>
          <a href="#" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        </div>
      </div>

      <!-- Column 3 — Quick Links -->
      <div class="footer-col footer-col--links">
        <p class="footer-col-heading">Quick Links</p>
        <ul class="footer-links-list">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-bottom-left">
        <a href="/terms-conditions" class="footer-bottom-link">Terms &amp; Conditions</a>
        <span class="footer-bottom-dot">•</span>
        <a href="/privacy-policy" class="footer-bottom-link">Privacy Policy</a>
      </p>
      <p class="footer-bottom-right">
        &copy; EB-1A Green Card Coach {new Date().getFullYear()}
      </p>
    </div>
  </div>

</footer>

<style>
  .site-footer {
    background-color: var(--color-navy);
  }

  /* ── Body ───────────────────────────────────────────────── */
  .footer-body {
    padding-block: var(--sp-16) var(--sp-12);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1.2fr 0.8fr;
    gap: var(--sp-12);
    align-items: start;
  }

  /* ── Col 1 — Tagline ─────────────────────────────────────── */
  .footer-tagline {
    font-size: clamp(22px, 2.5vw, 36px);
    line-height: 1.25;
    color: var(--color-white);
  }

  /* ── Col 2 — Contact ─────────────────────────────────────── */
  .footer-logo {
    display: inline-flex;
    margin-bottom: var(--sp-2);
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .footer-brand-name {
    font-family: var(--font-heading);
    font-size: var(--fs-body);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    margin-bottom: var(--sp-5);
  }

  .footer-contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    color: rgba(255,255,255,0.72);
    font-size: var(--fs-sm);
    line-height: 1.6;
  }

  .footer-contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-primary);
  }

  .footer-contact-item a,
  .footer-contact-item address {
    color: rgba(255,255,255,0.72);
    font-style: normal;
    transition: color var(--transition-sm);
  }

  .footer-contact-item a:hover { color: var(--color-white); }

  /* Social */
  .footer-social {
    display: flex;
    gap: var(--sp-3);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background-color: rgba(255,255,255,0.12);
    color: var(--color-white);
    transition: background-color var(--transition-sm);
  }

  .footer-social-link:hover { background-color: var(--color-primary); }

  /* ── Col 3 — Links ───────────────────────────────────────── */
  .footer-col-heading {
    font-family: var(--font-heading);
    font-size: var(--fs-h4);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    margin-bottom: var(--sp-5);
    padding-bottom: var(--sp-4);
    border-bottom: 2px solid var(--color-primary);
    display: inline-block;
  }

  .footer-links-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-sm);
    color: rgba(255,255,255,0.72);
    transition: color var(--transition-sm), gap var(--transition-sm);
  }

  .footer-link:hover { color: var(--color-white); gap: var(--sp-3); }
  .footer-link svg { color: var(--color-primary); flex-shrink: 0; }

  /* ── Bottom Bar ──────────────────────────────────────────── */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-block: var(--sp-5);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .footer-bottom-left,
  .footer-bottom-right {
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.55);
  }

  .footer-bottom-link {
    color: rgba(255,255,255,0.55);
    transition: color var(--transition-sm);
  }

  .footer-bottom-link:hover { color: var(--color-white); }

  .footer-bottom-dot {
    display: inline-block;
    margin-inline: var(--sp-3);
    opacity: 0.5;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-10);
    }

    .footer-col--tagline {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-col--tagline { grid-column: auto; }
    .footer-bottom-inner { flex-direction: column; text-align: center; }
  }
</style>
