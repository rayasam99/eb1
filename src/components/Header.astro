---
const navLinks = [
  { label: 'Home',           href: '/' },
  { label: 'Who Are We',     href: '/who-are-we' },
  { label: 'What Is EB-1A?', href: '/what-is-eb-1a' },
  { label: 'Blog',           href: '/blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label="EB-1A Green Card Coach Home">
      <img
        src="/images/EB-1A-Logo-For-Web.png"
        alt="EB-1A Green Card Coach — A Division of CodeBoru LLC"
        width="180"
        height="60"
        class="logo-img"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="nav-desktop" aria-label="Primary navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'nav-link--active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA Button -->
    <a href="/contact-us" class="btn btn-primary header-cta">
      Contact Us
    </a>

    <!-- Mobile Hamburger -->
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Toggle mobile menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="mobile-nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`mobile-nav-link ${currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'mobile-nav-link--active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a href="/contact-us" class="btn btn-primary mobile-cta">
            Contact Us
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ── Header Shell ───────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    background-color: var(--color-white);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--sp-6);
  }

  /* ── Logo ───────────────────────────────────────────────── */
  .logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 56px;
    width: auto;
    object-fit: contain;
  }

  /* ── Desktop Nav ────────────────────────────────────────── */
  .nav-desktop {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--fs-nav);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-nav);
    color: var(--color-text-nav);
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--radius-sm);
    transition: color var(--transition-sm);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: var(--sp-4);
    right: var(--sp-4);
    height: 2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--transition-sm);
    border-radius: var(--radius-full);
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link:hover::after,
  .nav-link--active::after {
    transform: scaleX(1);
  }

  .nav-link--active {
    color: var(--color-primary);
    font-weight: var(--fw-semibold);
  }

  /* ── CTA ────────────────────────────────────────────────── */
  .header-cta {
    flex-shrink: 0;
  }

  /* ── Hamburger ──────────────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: var(--sp-2);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-sm);
    flex-shrink: 0;
  }

  .hamburger:hover {
    background-color: var(--color-light-gray);
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-heading);
    border-radius: var(--radius-full);
    transition: transform var(--transition-sm), opacity var(--transition-sm);
  }

  /* Hamburger open state */
  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile Menu ────────────────────────────────────────── */
  .mobile-menu {
    display: none;
    background-color: var(--color-white);
    border-top: 1px solid var(--color-border);
    padding: var(--sp-4) var(--sp-5) var(--sp-6);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    max-height: 0;
    transition: max-height var(--transition-md), padding var(--transition-md);
  }

  .mobile-menu.is-open {
    max-height: 500px;
    padding-block: var(--sp-4) var(--sp-6);
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .mobile-nav-link {
    display: block;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    font-weight: var(--fw-medium);
    color: var(--color-text-nav);
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-sm), color var(--transition-sm);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link--active {
    background-color: var(--color-light-gray);
    color: var(--color-primary);
  }

  .mobile-cta {
    display: block;
    text-align: center;
    margin-top: var(--sp-4);
    width: 100%;
  }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 900px) {
    .nav-desktop,
    .header-cta {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }
</style>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
      menu.classList.toggle('is-open', !isOpen);
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
        btn.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.classList.remove('is-open');
      }
    });
  }
</script>
