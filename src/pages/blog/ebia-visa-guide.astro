    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }
  .post-date {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  /* Article typography */
  .post-title  { margin-bottom: var(--sp-6); color: var(--color-navy); }
  .post-heading    { color: var(--color-navy); margin-top: var(--sp-8); margin-bottom: var(--sp-3); }
  .post-subheading { color: var(--color-primary); margin-top: var(--sp-6); margin-bottom: var(--sp-2); }

  .post-content .text-body { margin-bottom: var(--sp-4); line-height: 1.8; }

  .post-list {
    list-style: disc;
    padding-left: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  .post-list--ordered { list-style: decimal; }
  .post-list li {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--color-text-body);
    line-height: 1.75;
  }

  .post-divider {
