  .post-back { margin-top: var(--sp-8); }
  .blog-readmore {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-primary);
    transition: gap var(--transition-sm);
  }
  .blog-readmore:hover { gap: var(--sp-3); }

