    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }
  .post-date {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  /* Article typography */
  .post-title  { margin-bottom: var(--sp-6); color: var(--color-navy); }
  .post-heading    { color: var(--color-navy); margin-top: var(--sp-8); margin-bottom: var(--sp-3); }
  .post-subheading { color: var(--color-primary); margin-top: var(--sp-6); margin-bottom: var(--sp-2); }

  .post-content .text-body { margin-bottom: var(--sp-4); line-height: 1.8; }

  .post-list {
    list-style: disc;
    padding-left: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  .post-list--ordered { list-style: decimal; }
  .post-list li {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--color-text-body);
    line-height: 1.75;
  }

  .post-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--sp-10) 0;
  }

  .post-link {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-link:hover { color: var(--color-navy); }

  /* CTA Box */
  .post-cta-box {
    background: var(--color-navy);
    color: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--sp-10) var(--sp-12);
    margin-top: var(--sp-12);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-4);
  }
  .post-cta-title { color: var(--color-white); }
  .post-cta-box .text-body { color: rgba(255,255,255,0.78); margin: 0; }

