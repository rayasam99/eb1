  .post-container { max-width: 860px; }

  /* Featured image */
  .post-featured-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--sp-8);
  }
  .post-featured-image img {
    width: 100%;
