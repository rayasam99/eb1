---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Who Are We | EB-1A Green Card Coach" description="Learn about EB-1A Green Card Coach — specialists in EB-1A, NIW, EB-2, and O-Visa petitions.">

  <PageHero
    eyebrow="Who Are We"
    heading={"Know About EB-1A\nGreen Card Coach"}
    ctaLabel="Request A Consultation"
    ctaHref="/contact-us"
  />

  <!-- ── Best EB1A Green Card Coaches ── -->
  <section class="section bg-white">
    <div class="container coaches-grid">

      <div class="coaches-left">
        <h2 class="heading-2">Best EB1A Green Card Coaches</h2>
        <hr class="divider" />
        <p class="text-body">
          At EB1A Green Card Coach, we specialize in assisting clients with EB1A green card petitions,
          as well as NIW (National Interest Waiver), EB-2 (Employment-Based), and O-Visa petitions.
          Headquartered in the USA, we are dedicated to providing top-notch representation for individuals
          navigating the complex immigration process.
        </p>
        <p class="text-body">
          Our team at EB1A Green Card Coach boasts extensive expertise in handling EB1A immigration
          petitions, with a track record of successful outcomes for our clients. Whether you're seeking
          guidance on EB1A visas, NIW, EB-2, or O-Visa petitions, our experienced coaches are here
          to help you achieve your immigration goals.
        </p>
        <a href="/contact-us" class="btn btn-primary coaches-cta">Request A Consultation</a>
      </div>

      <div class="coaches-right">
        <p class="text-body coaches-right-text">
          Staying abreast of the latest immigration trends, legal requirements, and USCIS judicial
          opinions is paramount to our approach. Our team conducts comprehensive research to ensure
          we have a thorough understanding of the intricacies involved in each case. This diligent
          effort allows us to develop strategic plans tailored to the unique needs of our clients,
          increasing the likelihood of a favorable outcome.
        </p>
        <p class="text-body coaches-right-text">
          By choosing EB1A Green Card Coach, you're partnering with a team committed to excellence,
          professionalism, and achieving results. Let us guide you through the complexities of the
          EB1A immigration journey and help you secure a brighter future in the United States.
        </p>
        <ul class="coaches-services">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            EB-1A Visa (Extraordinary Ability)
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            NIW (National Interest Waiver)
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            EB-2 (Employment-Based 2)
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            O-Visa
          </li>
        </ul>
      </div>

    </div>

    <!-- Two images side by side -->
    <div class="container">
      <div class="about-images-row">
        <img src="/images/EB-1A-About-Us-2.jpg" alt="EB-1A Team" class="about-img" width="560" height="340" />
        <img src="/images/EB-1A-About-Us-3.jpg" alt="EB-1A Coaches" class="about-img" width="560" height="340" />
      </div>
    </div>
  </section>

  <!-- ── Stats ── -->
  <section class="section bg-light stats-section">
    <div class="container stats-grid">
      <div class="stat-item">
        <p class="stat-number">1500<span class="stat-plus">+</span></p>
        <p class="stat-label">Clients Served</p>
      </div>
      <div class="stat-item">
        <p class="stat-number">10<span class="stat-plus">+</span></p>
        <p class="stat-label">Years of Experience</p>
      </div>
      <div class="stat-item">
        <p class="stat-number">6<span class="stat-plus">+</span></p>
        <p class="stat-label">Years in Business</p>
      </div>
      <div class="stat-item">
        <p class="stat-number">800<span class="stat-plus">+</span></p>
        <p class="stat-label">Happy Clients</p>
      </div>
    </div>
  </section>

  <!-- ── Building Bridges ── -->
  <section class="section bg-white">
    <div class="container bridges-grid">

      <div class="bridges-content">
        <h2 class="heading-2">Building Bridges, Changing Lives with EB1A Green Card</h2>
        <hr class="divider" />
        <p class="text-body">
          At EB-1A Green Card Coach, we believe in the power of immigration to build bridges and change
          lives. We are proud to play a role in helping individuals from around the world achieve their
          dreams of living and working in the United States. By providing expert guidance, personalized
          assistance, and unwavering support, we empower our clients to unlock new opportunities and
          pursue their aspirations with confidence. Come with us as we move towards a brighter future,
          step by step.
        </p>
        <a href="/contact-us" class="btn btn-primary">Request A Consultation</a>
      </div>

      <div class="bridges-image-wrap">
        <img src="/images/EB-1A-About-Us-4.jpg" alt="Immigration success" class="bridges-image" width="520" height="400" />
      </div>

    </div>
  </section>

  <!-- ── About Card (image + features) ── -->
  <section class="afc-section">
    <div class="container">
    <div class="afc-card">
      <div class="afc-image-wrap">
        <img src="/images/EB-1A-About-Us-5.jpg" alt="Our team" class="afc-image" width="1200" height="500" />
      </div>
      <div class="afc-features">
        <div class="afc-features-grid">
          <div class="afc-feature">
            <div class="afc-icon-circle"><i class="fa-solid fa-table-columns"></i></div>
            <h3 class="heading-3 afc-feature-title">Specialized EB-1A Coaches</h3>
            <p class="afc-feature-desc">Our team of qualified coaches at EB-1A Green Card Coach provides expert guidance through the EB-1A immigration process.</p>
          </div>
          <div class="afc-feature">
            <div class="afc-icon-circle"><i class="fa-solid fa-people-group"></i></div>
            <h3 class="heading-3 afc-feature-title">Personalized Approach</h3>
            <p class="afc-feature-desc">We understand that every client is unique, and we take the time to understand their circumstances and goals</p>
          </div>
          <div class="afc-feature">
            <div class="afc-icon-circle"><i class="fa-solid fa-chart-line"></i></div>
            <h3 class="heading-3 afc-feature-title">Client Satisfaction</h3>
            <p class="afc-feature-desc">At EB-1A Coach, client satisfaction is our top priority. We work smart to make our clients happy by doing more than they expect</p>
          </div>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- ── Reviews Carousel ── -->
  <section class="section bg-white reviews-section">
    <div class="container reviews-inner">
      <div class="section-header-centered">
        <h2 class="heading-2">Our Client's Reviews</h2>
        <hr class="divider divider-center" />
      </div>
      <div class="testimonial-carousel">
        <div class="testimonial-track" id="waw-track">
          <div class="testimonial-slide">
            <blockquote class="testimonial-text">Thank you for your assistance in securing our green card. Your prompt responses to our inquiries were greatly appreciated throughout the process.</blockquote>
            <cite class="testimonial-author">William</cite>
          </div>
          <div class="testimonial-slide">
            <blockquote class="testimonial-text">The team assigned to our case was amazing. They were approachable, addressing all our queries with clarity, while maintaining a high level of professionalism. We are delighted with the successful outcome of our visa application.</blockquote>
            <cite class="testimonial-author">James</cite>
          </div>
          <div class="testimonial-slide">
            <blockquote class="testimonial-text">We are thankful for the support and responsiveness of the team. Working with them has been a pleasure, and we have received excellent guidance when needed.</blockquote>
            <cite class="testimonial-author">Thomas</cite>
          </div>
        </div>
        <div class="testimonial-dots" id="waw-dots">
          <button class="dot dot--active" data-index="0" aria-label="Slide 1"></button>
          <button class="dot" data-index="1" aria-label="Slide 2"></button>
          <button class="dot" data-index="2" aria-label="Slide 3"></button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Behind Our Work + Team ── -->
  <section class="section bg-white team-section">
    <div class="container">
      <div class="section-header-centered">
        <h2 class="heading-2">Behind Our Work</h2>
        <hr class="divider divider-center" />
        <p class="text-body team-intro">
          The legal professionals at EB-1A Green Card Coach boast decades of collective experience in U.S.
          immigration law. Our adept team facilitates cross-border talent acquisition for companies,
          facilitates employment opportunities for foreign workers in the U.S., and aids immigrants in
          reuniting with their families within the U.S.
        </p>
      </div>

      <div class="team-grid">
        <div class="team-card">
          <div class="team-card-image-wrap">
            <img src="/images/team-wade.png" alt="Wade Warren" class="team-card-image" width="400" height="420" />
          </div>
          <p class="team-name">Wade Warren, B.Sc.</p>
          <p class="team-role">CEO of company name</p>
        </div>
        <div class="team-card">
          <div class="team-card-image-wrap">
            <img src="/images/team-esther.png" alt="Esther Howard" class="team-card-image" width="400" height="420" />
          </div>
          <p class="team-name">Esther Howard, B.Sc.</p>
          <p class="team-role">COO of company name</p>
        </div>
        <div class="team-card">
          <div class="team-card-image-wrap">
            <img src="/images/team-jenny.png" alt="Jenny Wilson" class="team-card-image" width="400" height="420" />
          </div>
          <p class="team-name">Jenny Wilson, B.Sc.</p>
          <p class="team-role">CPO of company name</p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  /* ── Coaches ── */
  .coaches-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    margin-bottom: var(--sp-12);
  }

  .coaches-left { display: flex; flex-direction: column; gap: var(--sp-5); }
  .coaches-right { display: flex; flex-direction: column; gap: var(--sp-5); }

  .coaches-right-text { color: var(--color-text-body); }

  .coaches-services {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-2);
  }

  .coaches-services li {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--color-text-body);
  }

  .coaches-services li svg { color: var(--color-primary); flex-shrink: 0; }

  .coaches-cta { align-self: flex-start; margin-top: var(--sp-4); }

  .about-images-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
    margin-top: var(--sp-2);
  }

  .about-img { width: 100%; height: 280px; object-fit: cover; border-radius: var(--radius-md); display: block; }

  /* ── Stats ── */
  .stats-section { padding-block: var(--sp-12); }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-8);
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: var(--fw-bold);
    color: var(--color-navy);
    line-height: 1;
    margin-bottom: var(--sp-2);
  }

  .stat-plus { color: var(--color-primary); }
  .stat-label { font-family: var(--font-body); font-size: var(--fs-body); color: var(--color-text-body); }

  /* ── Bridges ── */
  .bridges-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: center;
  }

  .bridges-content { display: flex; flex-direction: column; gap: var(--sp-5); }

  .bridges-image-wrap { border-radius: var(--radius-md); overflow: hidden; }
  .bridges-image { width: 100%; height: 400px; object-fit: cover; display: block; }

  /* ── AFC Card (reused) ── */
  .afc-section { background-color: var(--color-white); padding-bottom: var(--sp-20); }

  .afc-card {
    width: 100%;
    border: 4px solid var(--color-navy);
    border-radius: 18px;
    background-color: var(--color-primary);
    overflow: hidden;
  }

  .afc-image-wrap { padding: 14px 14px 0 14px; }

  .afc-image { width: 100%; height: 420px; object-fit: cover; object-position: center top; display: block; border-radius: 10px 10px 0 0; }

  .afc-features {
    background-color: var(--color-primary);
    background-image: repeating-linear-gradient(-45deg, transparent, transparent 10px, rgba(0,0,0,0.13) 10px, rgba(0,0,0,0.13) 11px);
    padding: 44px 48px;
  }

  .afc-features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-10); }

  .afc-feature { display: flex; flex-direction: column; gap: var(--sp-4); }

  .afc-icon-circle {
    display: flex; align-items: center; justify-content: center;
    width: 52px; height: 52px;
    border-radius: var(--radius-full);
    background-color: var(--color-navy);
    color: var(--color-white);
    font-size: 20px; flex-shrink: 0;
  }

  .afc-feature-title { font-size: 20px; color: var(--color-white) !important; }

  .afc-feature-desc { font-family: var(--font-body); font-size: var(--fs-sm); line-height: var(--lh-body); color: rgba(255,255,255,0.78); }

  /* ── Reviews ── */
  .reviews-inner { text-align: center; }

  .testimonial-carousel { max-width: 760px; margin-inline: auto; margin-top: var(--sp-10); overflow: hidden; }

  .testimonial-track { display: flex; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }

  .testimonial-slide { min-width: 100%; display: flex; flex-direction: column; align-items: center; gap: var(--sp-6); padding-inline: var(--sp-4); }

  .testimonial-text { font-family: var(--font-heading); font-style: italic; font-size: 18px; line-height: 1.85; color: var(--color-text-body); text-align: center; }

  .testimonial-author { font-family: var(--font-body); font-size: var(--fs-body); font-weight: var(--fw-semibold); color: var(--color-text-heading); font-style: normal; }

  .testimonial-dots { display: flex; justify-content: center; gap: var(--sp-3); margin-top: var(--sp-8); }

  .dot { width: 10px; height: 10px; border-radius: var(--radius-full); background-color: var(--color-border-dark); border: none; cursor: pointer; padding: 0; transition: background-color var(--transition-sm), transform var(--transition-sm); }

  .dot--active { background-color: var(--color-primary); transform: scale(1.25); }

  /* ── Team ── */
  .team-intro { max-width: 700px; margin-inline: auto; margin-top: var(--sp-4); margin-bottom: var(--sp-12); }

  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-8); }

  .team-card { display: flex; flex-direction: column; gap: var(--sp-3); }

  .team-card-image-wrap { border-radius: var(--radius-md); overflow: hidden; background: var(--color-light-gray); }

  .team-card-image { width: 100%; height: 320px; object-fit: cover; object-position: top; display: block; }

  .team-name { font-family: var(--font-heading); font-size: var(--fs-body); font-weight: var(--fw-bold); color: var(--color-text-heading); }

  .team-role { font-family: var(--font-body); font-size: var(--fs-sm); color: var(--color-text-muted); }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .coaches-grid, .bridges-grid { grid-template-columns: 1fr; }
    .about-images-row { grid-template-columns: 1fr; }
    .afc-features-grid { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .afc-features { padding: 32px 24px; }
  }
</style>

<script>
  const track = document.getElementById('waw-track') as HTMLElement;
  const dots  = document.querySelectorAll<HTMLButtonElement>('#waw-dots .dot');
  const total = dots.length;
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('dot--active', i === current));
  }

  function startAuto() { timer = setInterval(() => goTo(current + 1), 5000); }
  function resetAuto()  { clearInterval(timer); startAuto(); }

  dots.forEach(dot => { dot.addEventListener('click', () => { goTo(Number(dot.dataset.index)); resetAuto(); }); });
  startAuto();
</script>
